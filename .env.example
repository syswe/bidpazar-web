# .env.example
# Copy this file to .env and fill in your actual values

# ===== APPLICATION URLs =====
# Server-side only (API routes, server components)
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# Client-side accessible (browser bundles)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ===== SOCKET.IO CONFIGURATION =====
# Client-side accessible
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=/socket.io

# Server-side only
SOCKET_URL=http://localhost:3000
WS_URL=/socket.io
SOCKET_LOG_LEVEL=debug

# ===== SERVER CONFIGURATION =====
# Server-side only
PORT=3000
PORT_SOCKET=3000
NODE_ENV=development

# ===== DATABASE =====
# Server-side only - NEVER prefix with NEXT_PUBLIC_
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# ===== AUTHENTICATION =====
# Server-side only - CRITICAL: Never expose secrets to client
# Generate strong secrets for production
JWT_SECRET="your-super-secret-jwt-key-here"
NEXTAUTH_SECRET="your-super-secret-nextauth-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ===== SMS CONFIGURATION =====
# Server-side only - NEVER expose API credentials to client
# Replace with your SMS provider credentials
SMS_USERNAME=your_sms_username
SMS_PASSWORD=your_sms_password
SMS_ORIGIN=your_sms_origin_number
SMS_API_URL=https://your-sms-provider.com/api
SEND_MESSAGE=mock

# ===== DEBUG CONFIGURATION =====
# Server-side only - Controls log levels
# Set to 'true' to enable specific debug logs
DEBUG_AUTH=false
DEBUG_NOTIFICATIONS=false
DEBUG_MESSAGES=false
DEBUG_CHAT=false

# ===== APP VERSION =====
# Server-side only - Used for token validation
APP_VERSION=1.0.0 