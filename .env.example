NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
BACKEND_API_URL=http://localhost:3000/api

# Server configuration
PORT=3000
PORT_SOCKET=3001  # For development separate Socket.IO port
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bidpazar?schema=public"

# Authentication
JWT_SECRET="your-jwt-secret"
JWT_EXPIRES_IN="7d"
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Socket.IO configuration
SOCKET_URL=ws://localhost:3001
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3001
WS_URL=/socket.io
NEXT_PUBLIC_WS_URL=/socket.io
SOCKET_LOG_LEVEL=debug

# WebRTC configuration
NEXT_PUBLIC_WEBRTC_SERVER="http://localhost:3000"
WEBRTC_SERVER="http://localhost:3000"

# WebRTC NAT Traversal 
NEXT_PUBLIC_TURN_SERVER_URL="turn:localhost:3478"
NEXT_PUBLIC_TURN_USERNAME="bidpazar"
NEXT_PUBLIC_TURN_PASSWORD="bidpazarpass"
NEXT_PUBLIC_STUN_SERVER_URL="stun:localhost:3478"

# MediaSoup (WebRTC)
MEDIASOUP_LISTEN_IP="0.0.0.0"
MEDIASOUP_ANNOUNCED_IP="127.0.0.1"
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
MEDIASOUP_WORKERS=1

# HLS Streaming
RTMP_SERVER_HOST="localhost"
NEXT_PUBLIC_RTMP_SERVER_HOST="localhost"
FFMPEG_PATH="/usr/bin/ffmpeg" 