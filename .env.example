NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
BACKEND_API_URL=http://localhost:3000/api
SOCKET_URL=ws://localhost:3001/
WEBRTC_SERVER=http://localhost:3001/
WS_URL=/socket.io/


# If you need a separate backend API endpoint, add:
# NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3000/api
PORT=3000
PORT_SOCKET=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bidpazar?schema=public"

# Authentication
JWT_SECRET="your-secret-key"
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Real-time Communication
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3001
NEXT_PUBLIC_WEBRTC_SERVER=http://localhost:3001
# Socket.IO path
NEXT_PUBLIC_WS_URL=/socket.io/
SOCKET_LOG_LEVEL=debug

# WebRTC NAT Traversal 
NEXT_PUBLIC_TURN_SERVER_URL="turn:localhost:3478"
NEXT_PUBLIC_TURN_USERNAME="bidpazar"
NEXT_PUBLIC_TURN_PASSWORD="bidpazarpass"
TURN_USERNAME="bidpazar"
TURN_PASSWORD="bidpazarpass"
NEXT_PUBLIC_STUN_SERVER_URL="stun:localhost:3478"
TURN_SERVER_URL="turn:localhost:3478"
STUN_SERVER_URL="stun:localhost:3478"

# MediaSoup (WebRTC)
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
MEDIASOUP_WORKERS=1 