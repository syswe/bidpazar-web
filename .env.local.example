# .env.local.example
# Copy this file to .env.local and modify as needed for your local environment

# ===== APPLICATION URLs =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# ===== SOCKET.IO CONFIGURATION =====
# CRITICAL: For local development, DO NOT use localhost or 127.0.0.1
# Instead, use your actual machine's network IP address so that
# devices on your network can connect to your WebRTC server
# Run 'ipconfig' (Windows) or 'ifconfig' (Mac/Linux) to find your IP

# Replace with your actual machine's IP address
MY_LOCAL_IP=192.168.x.x

# Use your actual IP for WebSocket connections
NEXT_PUBLIC_SOCKET_URL=ws://${MY_LOCAL_IP}:3000
SOCKET_URL=ws://${MY_LOCAL_IP}:3000
NEXT_PUBLIC_WS_URL=/socket.io/
WS_URL=/socket.io/
SOCKET_LOG_LEVEL=debug

# ===== MEDIASOUP WEBRTC CONFIGURATION =====
# Server Configuration - CRITICAL for WebRTC to work
MEDIASOUP_LISTEN_IP=0.0.0.0
# ⚠️ IMPORTANT: Replace with your actual local machine IP address
# DO NOT use 127.0.0.1 unless testing only on the same machine
MEDIASOUP_ANNOUNCED_IP=${MY_LOCAL_IP}
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
MEDIASOUP_LOG_LEVEL=debug

# WebRTC Server URL - used by client
NEXT_PUBLIC_WEBRTC_SERVER=http://${MY_LOCAL_IP}:3000
WEBRTC_SERVER=http://${MY_LOCAL_IP}:3000

# ===== STUN/TURN Server Configuration =====
# For local testing, you can use Google's public STUN server
NEXT_PUBLIC_STUN_SERVER_URL=stun:stun.l.google.com:19302
STUN_SERVER_URL=stun:stun.l.google.com:19302

# If you have a TURN server, uncomment and configure these
# NEXT_PUBLIC_TURN_SERVER_URL=turn:your-turn-server:3478
# NEXT_PUBLIC_TURN_USERNAME=username
# NEXT_PUBLIC_TURN_PASSWORD=password
# TURN_SERVER_URL=turn:your-turn-server:3478
# TURN_USERNAME=username
# TURN_PASSWORD=password 