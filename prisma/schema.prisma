generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  username           String             @unique
  password           String
  name               String?
  phoneNumber        String?            @unique
  verificationCode   String?
  isVerified         Boolean            @default(false)
  isAdmin            Boolean            @default(false)
  videoDeviceId      String?
  audioDeviceId      String?
  points             Int                @default(0)
  isPopularStreamer  Boolean            @default(false)
  isFavoriteSeller   Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  userType           UserType           @default(MEMBER)
  
  // Seller Quota System
  monthlyProductLimit    Int            @default(0)  // Total products allowed per month
  monthlyStreamMinutes   Int            @default(0)  // Total streaming minutes per month
  productsUsedThisMonth  Int            @default(0)  // Products posted this month
  streamMinutesUsedMonth Int            @default(0)  // Minutes streamed this month
  quotaResetDate         DateTime       @default(now()) // Last reset date
  
  bids             Bid[]
  chatMessages     ChatMessage[]
  liveStreams      LiveStream[]       @relation("HostedStreams")
  receivedMessages Message[]          @relation("ReceivedMessages")
  sentMessages     Message[]          @relation("SentMessages")
  notifications    Notification[]     @relation("UserNotifications")
  products         Product[]
  sellerRequests   SellerRequest[]
  stories          Story[]
  moderations      StreamModeration[] @relation("UserModerations")
  streamShares     StreamShare[]
  streamViewTimes  StreamViewTime[]
  receivedRewards  StreamReward[]     @relation("RewardRecipients")
  viewedStreams    LiveStream[]       @relation("StreamViewers")
  conversations    Conversation[]     @relation("UserConversations")
  liveStreamBids   LiveStreamBid[]    @relation("LiveStreamBids")
  
  // Follow system
  followers        Follows[]          @relation("following")
  following        Follows[]          @relation("follower")
}

model Follows {
  follower    User     @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User     @relation("following", fields: [followingId], references: [id])
  followingId String
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Story {
  id        String    @id @default(cuid())
  content   String
  type      StoryType @default(TEXT)
  mediaUrl  String?
  userId    String
  views     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  expiresAt DateTime
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive, expiresAt])
  @@index([createdAt])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  description String?
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  emoji       String?
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  products    Product[]
}

model Product {
  id          String           @id @default(cuid())
  title       String
  description String
  price       Float
  currency    String           @default("TRY")
  userId      String
  categoryId  String
  isFeatured  Boolean          @default(false)
  isSold      Boolean          @default(false)
  soldAt      DateTime?
  soldTo      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  buyNowPrice Float?
  listings    AuctionListing[]
  category    Category         @relation(fields: [categoryId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  auctions    ProductAuction[]
  media       ProductMedia[]

  @@index([isFeatured])
}

model ProductMedia {
  id        String   @id @default(cuid())
  url       String
  type      String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
}

model LiveStream {
  id                String                @id @default(cuid())
  title             String
  description       String?
  thumbnailUrl      String?
  startTime         DateTime?
  endTime           DateTime?
  userId            String
  viewerCount       Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  status            StreamStatus            @default(SCHEDULED)
  listings          AuctionListing[]
  chatMessages      ChatMessage[]
  user              User                    @relation("HostedStreams", fields: [userId], references: [id])
  analytics         StreamAnalytics[]
  highlights        StreamHighlight[]
  moderation        StreamModeration[]
  rewards           StreamReward[]
  shares            StreamShare[]
  viewTimes         StreamViewTime[]
  viewers           User[]                  @relation("StreamViewers")
  liveStreamProducts LiveStreamProduct[]
}

model AuctionListing {
  id             String     @id @default(cuid())
  productId      String
  liveStreamId   String
  startPrice     Float
  status         String     @default("PENDING")
  countdownTime  Int?
  countdownStart DateTime?
  countdownEnd   DateTime?
  winningBidId   String?    @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  liveStream     LiveStream @relation(fields: [liveStreamId], references: [id])
  product        Product    @relation(fields: [productId], references: [id])
  winningBid     Bid?       @relation("WinningBid", fields: [winningBidId], references: [id])
  bids           Bid[]
}

model Bid {
  id                String          @id @default(cuid())
  amount            Float
  userId            String
  listingId         String?
  isWinning         Boolean         @default(false)
  isBackup          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  productAuctionId  String?
  wonAuction        AuctionListing? @relation("WinningBid")
  listing           AuctionListing? @relation(fields: [listingId], references: [id])
  productAuction    ProductAuction? @relation(fields: [productAuctionId], references: [id])
  user              User            @relation(fields: [userId], references: [id])
  wonProductAuction ProductAuction? @relation("WinningProductBid")
}

model ChatMessage {
  id           String     @id @default(cuid())
  message      String
  userId       String
  liveStreamId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  participants User[]    @relation("UserConversations")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  senderId       String
  receiverId     String
  conversationId String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  content   String
  type      String
  isRead    Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id])
}

model StreamHighlight {
  id           String     @id @default(cuid())
  title        String
  description  String?
  timestamp    Int
  duration     Int
  thumbnailUrl String?
  liveStreamId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  likes        Int        @default(0)
  videoUrl     String?
  views        Int        @default(0)
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id])
}

model StreamReward {
  id           String     @id @default(cuid())
  title        String
  description  String?
  points       Int
  type         String
  condition    Json
  liveStreamId String
  userIds      String[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id])
  recipients   User[]     @relation("RewardRecipients")
}

model StreamShare {
  id           String     @id @default(cuid())
  platform     String
  message      String?
  liveStreamId String
  userId       String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
}

model StreamViewTime {
  id                String     @id @default(cuid())
  userId            String
  liveStreamId      String
  durationInSeconds Int
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  liveStream        LiveStream @relation(fields: [liveStreamId], references: [id])
  user              User       @relation(fields: [userId], references: [id])

  @@unique([userId, liveStreamId])
}

model StreamModeration {
  id           String     @id @default(cuid())
  liveStreamId String
  userId       String
  action       String
  reason       String?
  duration     Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id])
  user         User       @relation("UserModerations", fields: [userId], references: [id])
}

model StreamAnalytics {
  id           String     @id @default(cuid())
  liveStreamId String
  timestamp    DateTime
  viewerCount  Int
  messageCount Int
  bidCount     Int
  revenue      Float
  avgWatchTime Int
  peakViewers  Int
  engagement   Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id])
}

model ProductAuction {
  id                   String    @id @default(cuid())
  productId            String
  startPrice           Float
  currentPrice         Float     @default(0)
  minimumBidIncrement  Float     @default(100) // Minimum bid increment based on current price
  duration             Int
  status               String    @default("PENDING")
  startTime            DateTime?
  endTime              DateTime?
  winningBidId         String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  bids                 Bid[]
  product              Product   @relation(fields: [productId], references: [id])
  winningBid           Bid?      @relation("WinningProductBid", fields: [winningBidId], references: [id])
}

model SellerRequest {
  id                String              @id @default(cuid())
  userId            String
  fullName          String
  phoneNumber       String
  email             String
  productCategories String
  notes             String?
  status            SellerRequestStatus @default(PENDING)
  reviewedAt        DateTime?
  reviewedBy        String?
  reviewNotes       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model LiveStreamProduct {
  id                String     @id @default(cuid())
  title             String
  description       String?
  basePrice         Float
  currentPrice      Float      @default(0)
  imageUrl          String?
  stock             Int        @default(1)
  category          String?
  tags              String[]   @default([])
  
  // Live stream specific fields
  liveStreamId      String
  isActive          Boolean    @default(false)
  isAuctionMode     Boolean    @default(true)  // false for direct buy
  auctionDuration   Int?       // in seconds
  startTime         DateTime?
  endTime           DateTime?
  
  // Auction results
  winningBidId      String?    @unique
  isSold            Boolean    @default(false)
  soldAt            DateTime?
  soldPrice         Float?
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  // Relations
  liveStream        LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)
  bids              LiveStreamBid[]
  winningBid        LiveStreamBid? @relation("WinningLiveStreamBid", fields: [winningBidId], references: [id])
  
  @@index([liveStreamId])
  @@index([isActive])
}

model LiveStreamBid {
  id                    String            @id @default(cuid())
  amount                Float
  userId                String
  liveStreamProductId   String
  isWinning             Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  
  // Relations
  user                  User              @relation("LiveStreamBids", fields: [userId], references: [id])
  liveStreamProduct     LiveStreamProduct @relation(fields: [liveStreamProductId], references: [id], onDelete: Cascade)
  wonProduct            LiveStreamProduct? @relation("WinningLiveStreamBid")
  
  @@index([liveStreamProductId])
  @@index([userId])
}

enum StreamStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
  PAUSED
  STARTING
  ENDING
  FAILED_TO_START
  INTERRUPTED
}

enum ListingStatus {
  PENDING
  ACTIVE
  COUNTDOWN
  COMPLETED
  CANCELLED
}

enum NotificationType {
  BID_WON
  BID_OUTBID
  MESSAGE
  SYSTEM
}

enum RewardType {
  VIEWER
  BIDDER
  CHATTER
}

enum SharePlatform {
  TWITTER
  FACEBOOK
  WHATSAPP
  TELEGRAM
}

enum UserType {
  MEMBER
  SELLER
}

enum SellerRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StoryType {
  TEXT
  IMAGE
  VIDEO
}
