# .env
# ===== APPLICATION URLs =====
# Base URLs for frontend and API
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
# Comment out BACKEND_API_URL to prevent recursive API calls
# BACKEND_API_URL=http://localhost:3000/api
SOCKET_URL=ws://localhost:3001
WS_URL=/socket.io

# ===== SERVER CONFIGURATION =====
PORT=3000
PORT_SOCKET=3000
NODE_ENV=development

# ===== DATABASE =====
DATABASE_URL="postgresql://user:password@localhost:5432/bidpazar?schema=public"

# ===== AUTHENTICATION =====
JWT_SECRET="your-secret-key"
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# ===== SOCKET.IO CONFIGURATION =====
# Used by both server and client
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3000
SOCKET_URL=ws://localhost:3000
NEXT_PUBLIC_WS_URL=/socket.io
WS_URL=/socket.io
SOCKET_LOG_LEVEL=debug

