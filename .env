# .env
# ===== APPLICATION URLs =====
# Base URLs for frontend and API
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
# Comment out BACKEND_API_URL to prevent recursive API calls
# BACKEND_API_URL=http://localhost:3000/api
SOCKET_URL=ws://localhost:3000/
WEBRTC_SERVER=http://localhost:3000
WS_URL=/socket.io

# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=development

# ===== DATABASE =====
DATABASE_URL="postgresql://user:password@localhost:5432/bidpazar?schema=public"

# ===== AUTHENTICATION =====
JWT_SECRET="your-secret-key"
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# ===== SOCKET.IO CONFIGURATION =====
# Used by both server and client
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3000
SOCKET_URL=ws://localhost:3000
NEXT_PUBLIC_WS_URL=/socket.io
WS_URL=/socket.io
SOCKET_LOG_LEVEL=debug

# ===== MEDIASOUP WEBRTC CONFIGURATION =====
# Server Configuration - CRITICAL for WebRTC to work
MEDIASOUP_LISTEN_IP=0.0.0.0
# For local development, use your actual local network IP (not localhost or 127.0.0.1)
# Run "ipconfig" (Windows) or "ifconfig" (Mac/Linux) to find your IP
# MEDIASOUP_ANNOUNCED_IP=127.0.0.1
# ⚠️ IMPORTANT: Replace with your actual local machine IP address
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
MEDIASOUP_LOG_LEVEL=debug

# WebRTC Server URL - used by client
NEXT_PUBLIC_WEBRTC_SERVER=http://localhost:3000
WEBRTC_SERVER=http://localhost:3000

# STUN/TURN Server Configuration - for NAT traversal
# Public Google STUN server (fallback)
#NEXT_PUBLIC_STUN_SERVER_URL=stun:stun.l.google.com:19302
NEXT_PUBLIC_STUN_SERVER_URL=stun:45.147.46.183:3478
# Your TURN server (if available)
NEXT_PUBLIC_TURN_SERVER_URL=turn:45.147.46.183:3478
NEXT_PUBLIC_TURN_USERNAME=bidpazar
NEXT_PUBLIC_TURN_PASSWORD=bidpazarpass
# Server-side copies (if needed by server code)
#STUN_SERVER_URL=stun:stun.l.google.com:19302
STUN_SERVER_URL=stun:45.147.46.183:3478
TURN_SERVER_URL=turn:45.147.46.183:3478
TURN_USERNAME=bidpazar
TURN_PASSWORD=bidpazarpass

