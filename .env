# .env - Local Development Environment
# BidPazar Next.js Application

# ===== APPLICATION URLs =====
# Server-side only (API routes, server components)
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# Client-side accessible (browser bundles)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ===== SOCKET.IO CONFIGURATION =====
# Client-side accessible
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=/socket.io

# Server-side only
SOCKET_URL=http://localhost:3000
WS_URL=/socket.io
SOCKET_LOG_LEVEL=debug

# ===== SERVER CONFIGURATION =====
# Server-side only
PORT=3000
NODE_ENV=development

# ===== DATABASE =====
# Server-side only - NEVER prefix with NEXT_PUBLIC_
# PostgreSQL zaten ayrı yerde çalışıyor
DATABASE_URL="postgresql://user:password@localhost:5432/bidpazar?schema=public"

# ===== AUTHENTICATION =====
# Server-side only - CRITICAL: Never expose secrets to client
JWT_SECRET=bidpazar2025
NEXTAUTH_SECRET=bidpazar2025
NEXTAUTH_URL=http://localhost:3000

# ===== SMS CONFIGURATION =====
# Server-side only
SMS_USERNAME=bidpazar
SMS_PASSWORD=lAJ5HgcV23HgeSYg
SMS_ORIGIN=908505518624
SMS_API_URL=https://smsgw.mutlucell.com/smsgw-ws/sndblkex
SEND_MESSAGE=real

# ===== DEBUG CONFIGURATION =====
# Server-side only - Controls log levels
DEBUG_AUTH=false
DEBUG_NOTIFICATIONS=false
DEBUG_MESSAGES=false
DEBUG_CHAT=false
DEBUG_ACTIVE_BID=false
NEXT_PUBLIC_DEBUG_ACTIVE_BID=false
# ===== APP VERSION =====
# Server-side only - Used for token validation
APP_VERSION=1.0.0

# ===== LIVEKIT CONFIGURATION =====
# Server-side only - API credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=dev-secret-key-at-least-32-characters-long-for-security
LIVEKIT_URL=http://localhost:7880

# Client-side accessible - Use ws:// for WebSocket connections
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ===== REDIS CONFIGURATION =====
# Server-side only - Redis Docker container
REDIS_URL=redis://:redis_dev_password@localhost:6379

# ===== WEBRTC/TURN CONFIGURATION =====
# Client-side accessible - Use Google STUN servers for NAT traversal
NEXT_PUBLIC_STUN_SERVER_URL=stun:stun.l.google.com:19302

# Disable local TURN server - use public STUN only
NEXT_PUBLIC_TURN_SERVER_URL=turn:localhost:3478
NEXT_PUBLIC_TURN_USERNAME=bidpazar_dev
NEXT_PUBLIC_TURN_PASSWORD=coturn_dev_secret

# WebRTC server configuration
NEXT_PUBLIC_WEBRTC_SERVER=http://localhost:3000