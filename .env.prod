# ===== APPLICATION URLs =====
# Base URLs for frontend and API
NEXT_PUBLIC_APP_URL=https://bidpazar.com
NEXT_PUBLIC_API_URL=https://bidpazar.com/api
APP_URL=https://bidpazar.com
API_URL=https://bidpazar.com/api
BACKEND_API_URL=https://bidpazar.com/api

# ===== SERVER CONFIGURATION =====
PORT=3000
PORT_SOCKET=3001 # Always use a separate port for Socket.IO
NODE_ENV=production

# ===== DATABASE =====
DATABASE_URL="postgresql://user:password@postgres:5432/bidpazar?schema=public"

# ===== AUTHENTICATION =====
JWT_SECRET=bidpazar2025
NEXTAUTH_SECRET=bidpazar2025
NEXTAUTH_URL="https://bidpazar.com"

# ===== SOCKET.IO CONFIGURATION =====
# Used by both server and client
# Option 1: Using a subdomain approach
NEXT_PUBLIC_SOCKET_URL=wss://ws.bidpazar.com
SOCKET_URL=wss://ws.bidpazar.com

# Socket.IO path (must match Nginx configuration)
NEXT_PUBLIC_WS_URL=/socket.io
WS_URL=/socket.io
SOCKET_LOG_LEVEL=info

# ===== MEDIASOUP WEBRTC CONFIGURATION =====
# Server Configuration - CRITICAL for WebRTC to work
MEDIASOUP_LISTEN_IP=0.0.0.0
# For production, this MUST be your server's public IP address
# The IP that clients will connect to for WebRTC media
MEDIASOUP_ANNOUNCED_IP=45.147.46.183
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
MEDIASOUP_LOG_LEVEL=warn

# WebRTC Server URL - used by client
NEXT_PUBLIC_WEBRTC_SERVER=https://bidpazar.com/
WEBRTC_SERVER=https://bidpazar.com/

# STUN/TURN Server Configuration - for NAT traversal
# Public Google STUN server
NEXT_PUBLIC_STUN_SERVER_URL=stun:stun.l.google.com:19302
# Twilio TURN server (more reliable for production)
NEXT_PUBLIC_TURN_SERVER_URL=turn:global.turn.twilio.com:3478
NEXT_PUBLIC_TURN_USERNAME=bidpazar
NEXT_PUBLIC_TURN_PASSWORD=bidpazarpass
# Server-side copies (if needed by server code)
STUN_SERVER_URL=stun:stun.l.google.com:19302
TURN_SERVER_URL=turn:45.147.46.183:3478
TURN_USERNAME=bidpazar
TURN_PASSWORD=bidpazarpass

# ===== HLS STREAMING CONFIGURATION =====
# RTMP server host for streaming - set to your server's public IP or hostname
RTMP_SERVER_HOST=bidpazar.com
NEXT_PUBLIC_RTMP_SERVER_HOST=bidpazar.com
# Path to ffmpeg executable for HLS transcoding
FFMPEG_PATH=/usr/bin/ffmpeg

