# .env.prod - Production environment variables

# ===== APPLICATION URLs =====
# Base URLs for frontend and API
NEXT_PUBLIC_APP_URL=https://bidpazar.com
NEXT_PUBLIC_API_URL=https://bidpazar.com/api
APP_URL=https://bidpazar.com
API_URL=https://bidpazar.com/api

# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=production

# ===== DATABASE =====
# Server-side only - NEVER expose to client
DATABASE_URL="postgresql://user:password@postgres:5432/bidpazar?schema=public"

# ===== AUTHENTICATION =====
# Server-side only - CRITICAL: Never expose secrets to client
JWT_SECRET=bidpazar2025
NEXTAUTH_SECRET=bidpazar2025
NEXTAUTH_URL="https://bidpazar.com"

# ===== SOCKET.IO CONFIGURATION =====
# Client-side accessible
NEXT_PUBLIC_SOCKET_URL=wss://ws.bidpazar.com
NEXT_PUBLIC_WS_URL=/socket.io

# Server-side only
SOCKET_URL=wss://ws.bidpazar.com
WS_URL=/socket.io
SOCKET_LOG_LEVEL=info

# ===== LIVEKIT CONFIGURATION =====
# Server-side only - NEVER expose API credentials to client
LIVEKIT_API_KEY=prodkey
LIVEKIT_API_SECRET=change-this-livekit-secret-key-in-production-at-least-32-chars
LIVEKIT_URL=https://bidpazar.com:7880

# Client-side accessible
NEXT_PUBLIC_LIVEKIT_URL=wss://bidpazar.com:7880

# ===== WEBRTC/TURN CONFIGURATION =====
# Client-side accessible for WebRTC connections
NEXT_PUBLIC_WEBRTC_SERVER=https://bidpazar.com/
NEXT_PUBLIC_STUN_SERVER_URL=stun:stun.l.google.com:19302
NEXT_PUBLIC_TURN_SERVER_URL=turn:207.180.247.20:3478
NEXT_PUBLIC_TURN_USERNAME=bidpazar_prod
NEXT_PUBLIC_TURN_PASSWORD=change_this_coturn_password_in_production

# Server-side only (if needed by server code)
WEBRTC_SERVER=https://bidpazar.com/
STUN_SERVER_URL=stun:stun.l.google.com:19302
TURN_SERVER_URL=turn:207.180.247.20:3478
TURN_USERNAME=bidpazar_prod
TURN_PASSWORD=change_this_coturn_password_in_production

# ===== SMS CONFIGURATION =====
# Server-side only - NEVER expose API credentials to client
SMS_USERNAME=bidpazar
SMS_PASSWORD=lAJ5HgcV23HgeSYg
SMS_ORIGIN=908505518624
SMS_API_URL=https://smsgw.mutlucell.com/smsgw-ws/sndblkex
SEND_MESSAGE=real

# ===== APP VERSION =====
# Server-side only
APP_VERSION=1.0.0

# ===== DEBUG CONFIGURATION =====
# Server-side only - Production should have minimal debug
DEBUG_AUTH=false
DEBUG_NOTIFICATIONS=false  
DEBUG_MESSAGES=false
DEBUG_CHAT=false
DEBUG_ACTIVE_BID=false

# Client-side debug control (should be false in production)
NEXT_PUBLIC_DEBUG_ACTIVE_BID=false 